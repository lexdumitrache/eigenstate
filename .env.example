# LLM provider — "anthropic" or "openai"
EIGENSTATE_LLM=anthropic

# Supply the key for whichever provider you chose above.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: comma-separated extra origins the backend will accept (CORS).
# Not needed for docker compose up — the default already covers localhost:80.
# CORS_ORIGINS=https://your-frontend.example.com
